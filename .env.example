# Backend API base URL (Laravel api/v1 prefix). Baked in at `npm run build`.
# Local dev (Vite): point at your Laravel server.
VITE_BASE_URL=http://localhost:8000/api/v1
# Production (separate API host): e.g. VITE_BASE_URL=https://api.yourdomain.com/api/v1
# Same host + Nginx /api proxy: you may omit this; production build falls back to window.location.origin + /api/v1
